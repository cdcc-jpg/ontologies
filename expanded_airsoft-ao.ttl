@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix schema: <http://schema.org/> .
# Use for: Events (skirmishes, MilSims), Organizations (teams, sites), and Products (gear).
@prefix foaf:   <http://xmlns.com/foaf/0.1/> .
# Use for: Players (foaf:Person) and Teams (foaf:Group).
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
# Use for: Hierarchies and categories. Perfect for classifying camouflage patterns (e.g., Multicam, M81) or game modes (e.g., TDM, Capture the Flag).
@prefix dcterms: <http://purl.org/dc/terms/> .
# Use for: Metadata about your ontology itself (creator, date created, description).
@prefix asoft: <https://github.com/cdcc-jpg/sportsontology/airsoft-ao#> .

@prefix bfo: <http://purl.obolibrary.org/obo/BFO_> .
@prefix obo: <http://purl.obolibrary.org/obo/> .

asoft:AirsoftOntology rdf:type owl:Ontology ;
    dcterms:title "An Airsoft Ontology" ;
    dcterms:creator "clement.dhollande@leurn.co" ;
    dcterms:created "2024-05-20"^^xsd:date ;
    dcterms:description "A comprehensive ontology covering airsoft replicas, gear, and game rules." ;
    owl:versionInfo "1.0" .

asoft:AirsoftGame a skos:ConceptSchema, owl:Class .

# GENERAL CONCEPTS

asoft:AirsoftField a skos:Concept, owl:Class ;
    rdfs:subClassOf schema:Place ;
    skos:prefLabel "Airsoft field"@en ;
    skos:description "A place where airsoft is played."@en ;
    skos:inScheme asoft:AirsoftGame .

asoft:AirsoftGear a skos:Concept, owl:Class ;
    rdfs:subClassOf schema:Product ;
    skos:prefLabel "Airsoft gear"@en ;
    skos:description "A type of object specifically used to play airsoft."@en ;
    skos:inScheme asoft:AirsoftGame .

asoft:AirsoftRule a skos:Concept, owl:Class ;
    skos:prefLabel "Airsoft rule"@en ;
    skos:description "A type of pre-established rules specifically applied to play airsoft."@en ;
    skos:inScheme asoft:AirsoftGame .

asoft:AirsoftAgent a skos:Concept, owl:Class ;
    rdfs:subClassOf foaf:Agent ;
    skos:prefLabel "Airsoft agent"@en ;
    skos:description "A type of agent that participates in an airsoft game." ;
    skos:inScheme asoft:AirsoftGame .

# GENERAL PROCESSES

asoft:StandardAirsoftSchedule a owl:Class, bfo:0000015 ;
    skos:description "The ordered sequence of a standard game day." ;
    asoft:hasPhases ( asoft:Briefing asoft:GameStart asoft:LunchBreak asoft:GameEnd ) .

asoft:Briefing a skos:Concept, owl:Class ;
    rdfs:subClassOf bfo:0000015 ;
    skos:prefLabel "Briefing"@en ;
    skos:inScheme asoft:AirsoftGame .

asoft:GameStart a skos:Concept, owl:Class ;
    rdfs:subClassOf bfo:0000015 ;
    skos:prefLabel "Game Start"@en ;
    skos:inScheme asoft:AirsoftGame .

asoft:LunchBreak a skos:Concept, owl:Class ;
    rdfs:subClassOf bfo:0000015 ;
    skos:prefLabel "Lunch Break"@en ;
    skos:inScheme asoft:AirsoftGame .

asoft:GameEnd a skos:Concept, owl:Class ;
    rdfs:subClassOf bfo:0000015 ;
    skos:prefLabel "Game End"@en ;
    skos:inScheme asoft:AirsoftGame .

# SPECIFIC CONCEPTS (AirsoftField)

asoft:OutdoorAirsoftField a skos:Concept, owl:Class ;
    skos:prefLabel "Outdoor airsoft field"@en ;
    skos:description "A place located outdoor where airsoft is played."@en ;
    skos:broader asoft:AirsoftField ;
    rdfs:subClassOf asoft:AirsoftField ;
    skos:inScheme asoft:AirsoftGame .

asoft:IndoorAirsoftField a skos:Concept, owl:Class ;
    skos:prefLabel "Indoor airsoft field"@en ;
    skos:description "A place located indoor where airsoft is played."@en ;
    skos:broader asoft:AirsoftField ;
    rdfs:subClassOf asoft:AirsoftField ;
    skos:inScheme asoft:AirsoftGame .

# SPECIFIC CONCEPTS (AirsoftGear)

asoft:AirsoftClothing a skos:Concept, owl:Class ;
    skos:prefLabel "Airsoft vest"@en ;
    skos:altLabel "Airsoft Clothing"@en ;
    skos:description "A piece of gear worn on the body by the player."@en ;
    skos:broader asoft:AirsoftGear ;
    rdfs:subClassOf asoft:AirsoftGear ;
    skos:inScheme asoft:AirsoftGame .

asoft:EyeProtection a skos:Concept, owl:Class ;
    skos:prefLabel "Eye Protection"@en ;
    skos:description "Mandatory safety glasses, goggles, or masks worn to protect the eyes from BBs."@en ;
    skos:broader asoft:AirsoftClothing ;
    rdfs:subClassOf asoft:AirsoftClothing ;
    skos:inScheme asoft:AirsoftGame .

asoft:AirsoftReplica a skos:Concept, owl:Class ;
    skos:prefLabel "Airsoft replica"@en ;
    skos:description "A piece of gear that propels 0.6 polymer ballbearings (BBs)."@en ;
    skos:broader asoft:AirsoftGear ;
    rdfs:subClassOf asoft:AirsoftGear ;
    skos:inScheme asoft:AirsoftGame .

asoft:AirsoftConsumable a skos:Concept, owl:Class ;
    skos:prefLabel "Airsoft consumable"@en ;
    skos:description "A piece of consumable that allows physical interaction between players."@en ;
    skos:broader asoft:AirsoftGear ;
    rdfs:subClassOf asoft:AirsoftGear ;
    skos:inScheme asoft:AirsoftGame .

asoft:AirsoftBB a skos:Concept, owl:Class ;
    skos:prefLabel "Airsoft BB"@en ;
    skos:description "Spherical plastic or biodegradable projectiles fired by replicas."@en ;
    skos:broader asoft:AirsoftConsumable ;
    rdfs:subClassOf asoft:AirsoftConsumable ;
    skos:inScheme asoft:AirsoftGame .

# SPECIFIC CONCEPTS (AirsoftRule)

asoft:Kill a skos:Concept, owl:Class ;
    skos:prefLabel "Kill"@en ;
    skos:description "The rule that states that a player is not allowed to interact with other players."@en ;
    skos:broader asoft:AirsoftRule ;
    rdfs:subClassOf asoft:AirsoftRule ;
    skos:inScheme asoft:AirsoftGame .

asoft:PowerLimit a skos:Concept, owl:Class ;
    skos:prefLabel "Power limit"@en ;
    skos:description "The rule that imposes a maximum cinetic power limit applied to polymer BBs."@en ;
    skos:broader asoft:AirsoftRule ;
    rdfs:subClassOf asoft:AirsoftRule ;
    skos:inScheme asoft:AirsoftGame .

asoft:NoiseLimit a skos:Concept, owl:Class ;
    skos:prefLabel "Noise limit"@en ;
    skos:description "The rule that imposes a maximum sonic power limit emitted by consummables."@en ;
    skos:broader asoft:AirsoftRule ;
    rdfs:subClassOf asoft:AirsoftRule ;
    skos:inScheme asoft:AirsoftGame .

# SPECIFIC CONCEPTS (AirsoftAgent)

asoft:AirsoftMarshall a skos:Concept, owl:Class ;
    rdfs:subClassOf foaf:Person ;
    skos:prefLabel "Airsoft marshall"@en ;
    skos:description "A type of airsoft agent that enforces airsoft rules during an airsoft game." ;
    skos:broader asoft:AirsoftAgent ;
    rdfs:subClassOf asoft:AirsoftAgent ;
    skos:inScheme asoft:AirsoftGame .

asoft:AirsoftPlayer a skos:Concept, owl:Class ;
    rdfs:subClassOf foaf:Person ;
    skos:prefLabel "Airsoft player"@en ;
    skos:description "A type of airsoft agent that plays an airsoft game." ;
    skos:broader asoft:AirsoftAgent ;
    rdfs:subClassOf asoft:AirsoftAgent ;
    skos:inScheme asoft:AirsoftGame .

asoft:AirsoftManager a skos:Concept, owl:Class ;
    rdfs:subClassOf foaf:Person ;
    skos:prefLabel "Airsoft Manager"@en ;
    skos:description "A type of airsoft agent that organises an airsoft game." ;
    skos:broader asoft:AirsoftAgent ;
    rdfs:subClassOf asoft:AirsoftAgent ;
    skos:inScheme asoft:AirsoftGame .

asoft:AirsoftTeam a skos:Concept, owl:Class ;
    rdfs:subClassOf foaf:Group ;
    skos:prefLabel "Airsoft Team"@en ;
    skos:description "An organized group of airsoft players."@en ;
    skos:broader asoft:AirsoftAgent ;
    rdfs:subClassOf asoft:AirsoftAgent ;
    skos:inScheme asoft:AirsoftGame .

# SPECIFIC CONCEPTS (AirsoftReplica)

asoft:HpaReplica a skos:Concept, owl:Class ;
    skos:prefLabel "HPA replica"@en ;
    skos:description "A type of airsoft replica that uses a compress air tank to propel BBs."@en ;
    skos:broader asoft:AirsoftReplica ;
    rdfs:subClassOf asoft:AirsoftReplica .

asoft:GbbrReplica a skos:Concept, owl:Class ;
    skos:prefLabel "GBBR replica"@en ;
    skos:description "A type of airsoft replica that uses compressed gas in magazines to propel BBs."@en ;
    skos:broader asoft:AirsoftReplica ;
    rdfs:subClassOf asoft:AirsoftReplica .

asoft:ElectricReplica a skos:Concept, owl:Class ;
    skos:prefLabel "Electric replica"@en ;
    skos:description "A type of airsoft replica that uses an electric motor that compresses ambient air to propel BBs."@en ;
    skos:broader asoft:AirsoftReplica ;
    rdfs:subClassOf asoft:AirsoftReplica .

# GENERAL OBJECT PROPERTIES

asoft:hasPhases a owl:ObjectProperty ;
    rdfs:label "has phases"@en ;
    rdfs:subPropertyOf obo:BFO_0000051 ; 
    rdfs:domain asoft:StandardAirsoftSchedule ;
    rdfs:range rdf:List .

asoft:kills a owl:ObjectProperty ;
    rdfs:range asoft:AirsoftPlayer ;
    rdfs:domain asoft:AirsoftPlayer ;
    owl:inverseOf asoft:isKilledBy .

asoft:isKilledBy a owl:ObjectProperty ;
    rdfs:range asoft:AirsoftPlayer ;
    rdfs:domain asoft:AirsoftPlayer ;
    owl:inverseOf asoft:kills .

asoft:usesGear a owl:ObjectProperty ;
    rdfs:label "uses gear"@en ;
    rdfs:domain asoft:AirsoftPlayer ;
    rdfs:range asoft:AirsoftGear .

asoft:enforcesRule a owl:ObjectProperty ;
    rdfs:label "enforces rule"@en ;
    rdfs:domain asoft:AirsoftMarshall ;
    rdfs:range asoft:AirsoftRule .

asoft:playsOnField a owl:ObjectProperty ;
    rdfs:label "plays on field"@en ;
    rdfs:domain asoft:AirsoftPlayer ;
    rdfs:range asoft:AirsoftField .

asoft:belongsToTeam a owl:ObjectProperty ;
    rdfs:label "belongs to team"@en ;
    rdfs:domain asoft:AirsoftPlayer ;
    rdfs:range asoft:AirsoftTeam .

# GENERAL DATA PROPERTIES

asoft:hasPowerLimit a owl:DatatypeProperty ;
    rdfs:label "has power limit"@en ;
    rdfs:domain asoft:AirsoftReplica ;
    rdfs:range xsd:decimal .

asoft:hasFPS a owl:DatatypeProperty ;
    rdfs:label "has FPS"@en ;
    skos:description "Feet per second measurement of the replica."@en ;
    rdfs:domain asoft:AirsoftReplica ;
    rdfs:range xsd:integer .

asoft:hasAmmunitionCapacity a owl:DatatypeProperty ;
    rdfs:label "has ammunition capacity"@en ;
    rdfs:domain asoft:AirsoftReplica ;
    rdfs:range xsd:integer .

