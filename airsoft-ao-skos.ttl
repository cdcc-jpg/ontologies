@prefix bfo: <http://purl.obolibrary.org/obo/BFO_> .
@prefix obo: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix asoft: <https://github.com/cdcc-jpg/ontologies#> .
@prefix schema: <http://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <https://github.com/cdcc-jpg/ontologies> .

<https://github.com/cdcc-jpg/ontologies> rdf:type owl:Ontology .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/created
dcterms:created rdf:type owl:AnnotationProperty .

###  http://purl.org/dc/terms/creator
dcterms:creator rdf:type owl:AnnotationProperty .

###  http://purl.org/dc/terms/description
dcterms:description rdf:type owl:AnnotationProperty .

###  http://purl.org/dc/terms/hasVersion
dcterms:hasVersion rdf:type owl:AnnotationProperty .

###  http://purl.org/dc/terms/title
dcterms:title rdf:type owl:AnnotationProperty .

###  http://www.w3.org/2004/02/skos/core#altLabel
skos:altLabel rdf:type owl:AnnotationProperty .

###  http://www.w3.org/2004/02/skos/core#broadMatch
skos:broadMatch rdf:type owl:AnnotationProperty .

###  http://www.w3.org/2004/02/skos/core#broader
skos:broader rdf:type owl:AnnotationProperty .

###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty .

###  http://www.w3.org/2004/02/skos/core#inScheme
skos:inScheme rdf:type owl:AnnotationProperty .

###  http://www.w3.org/2004/02/skos/core#note
skos:note rdf:type owl:AnnotationProperty .

###  http://www.w3.org/2004/02/skos/core#prefLabel
skos:prefLabel rdf:type owl:AnnotationProperty .

###  http://www.w3.org/2004/02/skos/core#related
skos:related rdf:type owl:AnnotationProperty .

###  https://github.com/cdcc-jpg/ontologies#belongsToTeam
asoft:belongsToTeam rdfs:label "belongs to team"@en ;
                    rdf:type owl:AnnotationProperty ;
                    rdfs:subPropertyOf skos:related .

###  https://github.com/cdcc-jpg/ontologies#enforcesRule
asoft:enforcesRule rdfs:label "enforces rule"@en ;
                   rdf:type owl:AnnotationProperty ;
                   rdfs:subPropertyOf skos:related .

###  https://github.com/cdcc-jpg/ontologies#hasAmmunitionCapacity
asoft:hasAmmunitionCapacity rdfs:label "has ammunition capacity"@en ;
                            rdf:type owl:AnnotationProperty ;
                            rdfs:subPropertyOf skos:note .

###  https://github.com/cdcc-jpg/ontologies#hasFPS
asoft:hasFPS rdfs:label "has FPS"@en ;
             skos:definition "Feet per second measurement of the replica."@en ;
             rdf:type owl:AnnotationProperty ;
             rdfs:subPropertyOf skos:note .

###  https://github.com/cdcc-jpg/ontologies#hasPhases
asoft:hasPhases rdfs:label "has phases"@en ;
                rdf:type owl:AnnotationProperty ;
                rdfs:subPropertyOf skos:related .

###  https://github.com/cdcc-jpg/ontologies#hasPowerLimit
asoft:hasPowerLimit rdfs:label "has power limit"@en ;
                    rdf:type owl:AnnotationProperty ;
                    rdfs:subPropertyOf skos:note .

###  https://github.com/cdcc-jpg/ontologies#isKilledBy
asoft:isKilledBy rdfs:label "is killed by"@en ;
                 rdf:type owl:AnnotationProperty ;
                 rdfs:subPropertyOf skos:related .

###  https://github.com/cdcc-jpg/ontologies#kills
asoft:kills rdfs:label "kills"@en ;
            rdf:type owl:AnnotationProperty ;
            rdfs:subPropertyOf skos:related .

###  https://github.com/cdcc-jpg/ontologies#playsOnField
asoft:playsOnField rdfs:label "plays on field"@en ;
                   rdf:type owl:AnnotationProperty ;
                   rdfs:subPropertyOf skos:related .

###  https://github.com/cdcc-jpg/ontologies#usesGear
asoft:usesGear rdfs:label "uses gear"@en ;
               rdf:type owl:AnnotationProperty ;
               rdfs:subPropertyOf skos:related .

#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .

#################################################################
#    Object Properties
#################################################################

###  http://www.w3.org/2004/02/skos/core#memberList
skos:memberList rdf:type owl:ObjectProperty .

#################################################################
#    Data properties
#################################################################

###  http://www.co-ode.org/ontologies/ont.owl#maxWeight
<http://www.co-ode.org/ontologies/ont.owl#maxWeight> rdf:type owl:DatatypeProperty .

###  http://www.co-ode.org/ontologies/ont.owl#weight
<http://www.co-ode.org/ontologies/ont.owl#weight> rdf:type owl:DatatypeProperty ;
                                                  rdfs:range xsd:decimal .

#################################################################
#    Classes
#################################################################

###  http://www.w3.org/2004/02/skos/core#Concept
skos:Concept rdf:type owl:Class .

###  http://www.w3.org/2004/02/skos/core#ConceptScheme
skos:ConceptScheme rdf:type owl:Class .

###  http://www.w3.org/2004/02/skos/core#OrderedCollection
skos:OrderedCollection rdf:type owl:Class .

#################################################################
#    Individuals
#################################################################

###  https://github.com/cdcc-jpg/ontologies#AirsoftAgent
asoft:AirsoftAgent rdf:type owl:NamedIndividual ,
                            skos:Concept ;
                   skos:broadMatch foaf:Agent ;
                   skos:definition "A type of agent that participates in an airsoft game."@en ;
                   skos:inScheme asoft:AirsoftGame ;
                   skos:prefLabel "Airsoft agent"@en .

###  https://github.com/cdcc-jpg/ontologies#AirsoftBB
asoft:AirsoftBB rdf:type owl:NamedIndividual ,
                         skos:Concept ;
                skos:broader asoft:AirsoftConsumable ;
                skos:definition "Spherical plastic or biodegradable projectiles fired by replicas."@en ;
                skos:inScheme asoft:AirsoftGame ;
                skos:prefLabel "Airsoft BB"@en ;
                rdfs:Datatype "0.60"^^xsd:decimal .

###  https://github.com/cdcc-jpg/ontologies#AirsoftClothing
asoft:AirsoftClothing rdf:type owl:NamedIndividual ,
                               skos:Concept ;
                      skos:altLabel "Airsoft Clothing"@en ;
                      skos:broader asoft:AirsoftGear ;
                      skos:definition "A piece of gear worn on the body by the player."@en ;
                      skos:inScheme asoft:AirsoftGame ;
                      skos:prefLabel "Airsoft vest"@en .

###  https://github.com/cdcc-jpg/ontologies#AirsoftConsumable
asoft:AirsoftConsumable rdf:type owl:NamedIndividual ,
                                 skos:Concept ;
                        skos:broader asoft:AirsoftGear ;
                        skos:definition "A piece of consumable that allows physical interaction between players."@en ;
                        skos:inScheme asoft:AirsoftGame ;
                        skos:prefLabel "Airsoft consumable"@en .

###  https://github.com/cdcc-jpg/ontologies#AirsoftField
asoft:AirsoftField rdf:type owl:NamedIndividual ,
                            skos:Concept ;
                   skos:broadMatch schema:Place ;
                   skos:definition "A place where airsoft is played."@en ;
                   skos:inScheme asoft:AirsoftGame ;
                   skos:prefLabel "Airsoft field"@en .

###  https://github.com/cdcc-jpg/ontologies#AirsoftGame
asoft:AirsoftGame rdf:type owl:NamedIndividual ,
                           skos:ConceptScheme .

###  https://github.com/cdcc-jpg/ontologies#AirsoftGear
asoft:AirsoftGear rdf:type owl:NamedIndividual ,
                           skos:Concept ;
                  skos:broadMatch schema:Product ;
                  skos:definition "A type of object specifically used to play airsoft."@en ;
                  skos:inScheme asoft:AirsoftGame ;
                  skos:prefLabel "Airsoft gear"@en .

###  https://github.com/cdcc-jpg/ontologies#AirsoftManager
asoft:AirsoftManager rdf:type owl:NamedIndividual ,
                              skos:Concept ;
                     skos:broadMatch foaf:Person ;
                     skos:broader asoft:AirsoftAgent ;
                     skos:definition "A type of airsoft agent that organises an airsoft game."@en ;
                     skos:inScheme asoft:AirsoftGame ;
                     skos:prefLabel "Airsoft Manager"@en .

###  https://github.com/cdcc-jpg/ontologies#AirsoftMarshall
asoft:AirsoftMarshall rdf:type owl:NamedIndividual ,
                               skos:Concept ;
                      skos:broadMatch foaf:Person ;
                      skos:broader asoft:AirsoftAgent ;
                      skos:definition "A type of airsoft agent that enforces airsoft rules during an airsoft game."@en ;
                      skos:inScheme asoft:AirsoftGame ;
                      skos:prefLabel "Airsoft marshall"@en .

###  https://github.com/cdcc-jpg/ontologies#AirsoftOntology
asoft:AirsoftOntology rdf:type owl:NamedIndividual ,
                               skos:ConceptScheme ;
                      dcterms:created "2024-05-20"^^xsd:date ;
                      dcterms:creator "clement.dhollande@leurn.co" ;
                      dcterms:description "A comprehensive SKOS taxonomy covering airsoft replicas, gear, and game rules." ;
                      dcterms:hasVersion "1.0" ;
                      dcterms:title "An Airsoft Taxonomy" .

###  https://github.com/cdcc-jpg/ontologies#AirsoftPlayer
asoft:AirsoftPlayer rdf:type owl:NamedIndividual ,
                             skos:Concept ;
                    skos:broadMatch foaf:Person ;
                    skos:broader asoft:AirsoftAgent ;
                    skos:definition "A type of airsoft agent that plays an airsoft game."@en ;
                    skos:inScheme asoft:AirsoftGame ;
                    skos:prefLabel "Airsoft player"@en .

###  https://github.com/cdcc-jpg/ontologies#AirsoftReplica
asoft:AirsoftReplica rdf:type owl:NamedIndividual ,
                              skos:Concept ;
                     skos:broader asoft:AirsoftGear ;
                     skos:definition "A piece of gear that propels 0.6 polymer ballbearings (BBs)."@en ;
                     skos:inScheme asoft:AirsoftGame ;
                     skos:prefLabel "Airsoft replica"@en .

###  https://github.com/cdcc-jpg/ontologies#AirsoftRule
asoft:AirsoftRule rdf:type owl:NamedIndividual ,
                           skos:Concept ;
                  skos:definition "A type of pre-established rules specifically applied to play airsoft."@en ;
                  skos:inScheme asoft:AirsoftGame ;
                  skos:prefLabel "Airsoft rule"@en .

###  https://github.com/cdcc-jpg/ontologies#AirsoftTeam
asoft:AirsoftTeam rdf:type owl:NamedIndividual ,
                           skos:Concept ;
                  skos:broadMatch foaf:Group ;
                  skos:broader asoft:AirsoftAgent ;
                  skos:definition "An organized group of airsoft players."@en ;
                  skos:inScheme asoft:AirsoftGame ;
                  skos:prefLabel "Airsoft Team"@en .

###  https://github.com/cdcc-jpg/ontologies#Briefing
asoft:Briefing rdf:type owl:NamedIndividual ,
                        skos:Concept ;
               skos:broadMatch obo:BFO_0000015 ;
               skos:inScheme asoft:AirsoftGame ;
               skos:prefLabel "Briefing"@en .

###  https://github.com/cdcc-jpg/ontologies#ElectricReplica
asoft:ElectricReplica rdf:type owl:NamedIndividual ,
                               skos:Concept ;
                      skos:broader asoft:AirsoftReplica ;
                      skos:definition "A type of airsoft replica that uses an electric motor that compresses ambient air to propel BBs."@en ;
                      skos:inScheme asoft:AirsoftGame ;
                      skos:prefLabel "Electric replica"@en .

###  https://github.com/cdcc-jpg/ontologies#EyeProtection
asoft:EyeProtection rdf:type owl:NamedIndividual ,
                             skos:Concept ;
                    skos:broader asoft:AirsoftClothing ;
                    skos:definition "Mandatory safety glasses, goggles, or masks worn to protect the eyes from BBs."@en ;
                    skos:inScheme asoft:AirsoftGame ;
                    skos:prefLabel "Eye Protection"@en .

###  https://github.com/cdcc-jpg/ontologies#GameEnd
asoft:GameEnd rdf:type owl:NamedIndividual ,
                       skos:Concept ;
              skos:broadMatch obo:BFO_0000015 ;
              skos:inScheme asoft:AirsoftGame ;
              skos:prefLabel "Game End"@en .

###  https://github.com/cdcc-jpg/ontologies#GameStart
asoft:GameStart rdf:type owl:NamedIndividual ,
                         skos:Concept ;
                skos:broadMatch obo:BFO_0000015 ;
                skos:inScheme asoft:AirsoftGame ;
                skos:prefLabel "Game Start"@en .

###  https://github.com/cdcc-jpg/ontologies#GbbrReplica
asoft:GbbrReplica rdf:type owl:NamedIndividual ,
                           skos:Concept ;
                  skos:broader asoft:AirsoftReplica ;
                  skos:definition "A type of airsoft replica that uses compressed gas in magazines to propel BBs."@en ;
                  skos:inScheme asoft:AirsoftGame ;
                  skos:prefLabel "GBBR replica"@en .

###  https://github.com/cdcc-jpg/ontologies#HpaReplica
asoft:HpaReplica rdf:type owl:NamedIndividual ,
                          skos:Concept ;
                 skos:broader asoft:AirsoftReplica ;
                 skos:definition "A type of airsoft replica that uses a compress air tank to propel BBs."@en ;
                 skos:inScheme asoft:AirsoftGame ;
                 skos:prefLabel "HPA replica"@en .

###  https://github.com/cdcc-jpg/ontologies#IndoorAirsoftField
asoft:IndoorAirsoftField rdf:type owl:NamedIndividual ,
                                  skos:Concept ;
                         skos:broader asoft:AirsoftField ;
                         skos:definition "A place located indoor where airsoft is played."@en ;
                         skos:inScheme asoft:AirsoftGame ;
                         skos:prefLabel "Indoor airsoft field"@en .

###  https://github.com/cdcc-jpg/ontologies#Kill
asoft:Kill rdf:type owl:NamedIndividual ,
                    skos:Concept ;
           skos:broader asoft:AirsoftRule ;
           skos:definition "The rule that states that a player is not allowed to interact with other players."@en ;
           skos:inScheme asoft:AirsoftGame ;
           skos:prefLabel "Kill"@en .

###  https://github.com/cdcc-jpg/ontologies#LunchBreak
asoft:LunchBreak rdf:type owl:NamedIndividual ,
                          skos:Concept ;
                 skos:broadMatch obo:BFO_0000015 ;
                 skos:inScheme asoft:AirsoftGame ;
                 skos:prefLabel "Lunch Break"@en .

###  https://github.com/cdcc-jpg/ontologies#NoiseLimit
asoft:NoiseLimit rdf:type owl:NamedIndividual ,
                          skos:Concept ;
                 skos:broader asoft:AirsoftRule ;
                 skos:definition "The rule that imposes a maximum sonic power limit emitted by consummables."@en ;
                 skos:inScheme asoft:AirsoftGame ;
                 skos:prefLabel "Noise limit"@en .

###  https://github.com/cdcc-jpg/ontologies#OutdoorAirsoftField
asoft:OutdoorAirsoftField rdf:type owl:NamedIndividual ,
                                   skos:Concept ;
                          skos:broader asoft:AirsoftField ;
                          skos:definition "A place located outdoor where airsoft is played."@en ;
                          skos:inScheme asoft:AirsoftGame ;
                          skos:prefLabel "Outdoor airsoft field"@en .

###  https://github.com/cdcc-jpg/ontologies#PowerLimit
asoft:PowerLimit rdf:type owl:NamedIndividual ,
                          skos:Concept ;
                 skos:broader asoft:AirsoftRule ;
                 skos:definition "The rule that imposes a maximum cinetic power limit applied to polymer BBs."@en ;
                 skos:inScheme asoft:AirsoftGame ;
                 skos:prefLabel "Power limit"@en .

###  https://github.com/cdcc-jpg/ontologies#StandardAirsoftSchedule
asoft:StandardAirsoftSchedule rdf:type owl:NamedIndividual ,
                                       skos:OrderedCollection ;
                              skos:memberList ( asoft:Briefing asoft:GameStart asoft:LunchBreak asoft:GameEnd ) ;
                              skos:broadMatch obo:BFO_0000015 ;
                              skos:definition "The ordered sequence of a standard game day."@en ;
                              skos:inScheme asoft:AirsoftGame ;
                              skos:prefLabel "Standard Airsoft Schedule"@en .